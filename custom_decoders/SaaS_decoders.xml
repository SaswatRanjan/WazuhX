<decoder name="m365-login-anomaly">
  <prematch>Microsoft 365</prematch>
</decoder>

<decoder name="m365-login-anomaly-detail">
  <parent>m365-login-anomaly</parent>
  <regex>User login failed for (\S+)</regex>
  <order>user</order>
</decoder>

<decoder name="google-workspace-admin-change">
